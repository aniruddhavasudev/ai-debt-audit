{
  "name": "ai-debt-audit",
  "version": "1.17.0",
  "description": "Catches the garbage your AI assistant left behind — security shortcuts, secrets buried in git history, code nobody understands. One 0-100 score, 100% local, no LLM in the loop.",
  "keywords": [
    "ai",
    "technical-debt",
    "code-audit",
    "semgrep",
    "vibe-coding",
    "django",
    "flask",
    "nextjs",
    "supabase",
    "static-analysis"
  ],
  "author": "",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/aniruddhavasudev/ai-debt-audit.git"
  },
  "homepage": "https://github.com/aniruddhavasudev/ai-debt-audit",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "lib",
    "scripts",
    "rules",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "aidebt-scan": "./bin/aidebt-scan.js"
  },
  "scripts": {
    "gitmine": "node scripts/git-mine.js",
    "score": "node scripts/score.js",
    "scan": "node bin/aidebt-scan.js",
    "test": "node --test scripts/score.test.js && node scripts/test-degraded.js",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "jscpd": "^5.0.11"
  }
}
